# LLM 配置
# 智谱 / BigModel API Key
ZAI_API_KEY=your_api_key_here
# 智谱 / BigModel API 基础地址
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# 智谱限流/过载后的最大重试次数
ZHIPU_RETRY_ATTEMPTS=4
# 智谱首次重试等待秒数；后续按指数退避增长
ZHIPU_RETRY_BASE_DELAY=10
# 智谱单次重试等待上限秒数
ZHIPU_RETRY_MAX_DELAY=30
# 智谱在连续触发限流后，对后续请求追加的冷却秒数
ZHIPU_RATE_LIMIT_COOLDOWN=10
# 单个岗位因临时限流被暂缓后，重新进入待分析队列前的冷却秒数
SCREENING_DEFER_COOLDOWN_SECONDS=30
# DeepSeek API Key
DEEPSEEK_API_KEY=your_api_key_here
# DeepSeek OpenAI 兼容接口基础地址
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 默认 LLM 提供方，可选 zhipu / deepseek
LLM_PROVIDER=zhipu

# Boss 直聘（nodriver）配置
# 岗位详情页 ready 等待秒数
BOSS_DETAIL_READY_TIMEOUT_SEC=3
# 第二套聊天页 ready 等待秒数
BOSS_CHAT_READY_TIMEOUT_SEC=4
# 点击“立即沟通”后等待新聊天 target 或同 tab 跳转的秒数
BOSS_CHAT_TARGET_TIMEOUT_SEC=4
# 第二套聊天页首次未 ready 时追加等待秒数
BOSS_CHAT_NOT_READY_EXTRA_WAIT_SEC=3
# 第二套聊天页发送后等待消息真正出现在 DOM/HTML 中的验收秒数
BOSS_CHAT_SEND_VERIFY_TIMEOUT_SEC=5
# 通用调试开关：控制普通 debug 日志，以及 boss_debug 页面导出
BOSS_DEBUG=0
# 聊天页专项调试开关，默认关闭；只有排查 chat 跳转/发送问题时再打开
BOSS_CHAT_DEBUG=0
# 是否在登录完成后导出当前页面到 data/boss_debug，1=开启，0=关闭
BOSS_DUMP_AFTER_LOGIN=0
# 单个岗位发送失败后的自动重试次数；2 表示失败后最多再试 2 次
BOSS_APPLY_RETRIES=2
# 同一岗位累计失败多少次后跳过自动投递，避免死循环
BOSS_APPLY_MAX_FAILURES=3
# Chrome 用户数据目录；用于复用 Boss 登录态
BOSS_USER_DATA_DIR=.nodriver_user_data\\boss
# 如果 nodriver 在当前机器上找不到 Chrome，可显式指定浏览器 exe 路径
BROWSER_EXECUTABLE_PATH=
