# LLM 配置
# 智谱 / BigModel API Key
ZAI_API_KEY=your_api_key_here
# 智谱 / BigModel API 基础地址
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# DeepSeek API Key
DEEPSEEK_API_KEY=your_api_key_here
# DeepSeek OpenAI 兼容接口基础地址
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 默认 LLM 提供方，可选 zhipu / deepseek
LLM_PROVIDER=zhipu

# Boss 直聘（nodriver）配置
# 通用调试开关：控制普通 debug 日志，以及 boss_debug 页面导出
BOSS_DEBUG=0
# 聊天页专项调试开关，默认关闭；只有排查 chat 跳转/发送问题时再打开
BOSS_CHAT_DEBUG=0
# 是否在登录完成后导出当前页面到 data/boss_debug，1=开启，0=关闭
BOSS_DUMP_AFTER_LOGIN=0
# 单个岗位发送失败后的自动重试次数；2 表示失败后最多再试 2 次
BOSS_APPLY_RETRIES=2
# 同一岗位累计失败多少次后跳过自动投递，避免死循环
BOSS_APPLY_MAX_FAILURES=3
# Chrome 用户数据目录；用于复用 Boss 登录态
BOSS_USER_DATA_DIR=.nodriver_user_data\\boss
# 如果 nodriver 在当前机器上找不到 Chrome，可显式指定浏览器 exe 路径
BROWSER_EXECUTABLE_PATH=
